# 上游 Joplin 源码（仅作格式参考，自带独立 git 仓库，不纳入本项目）
/joplin/

# 个人笔记测试数据（隐私，勿提交）
/JopinData/

# Rust 构建产物
/server/target/
/core/target/
/wasm/target/
/plugin-sdk/target/
/plugins-examples/*/target/
# 示例插件 wasm 产物（plugins-examples/build-wasm.sh 生成；缺失时相关测试自动跳过）
/plugins-examples/*/plugin.wasm
# 手工打的安装包（zip of manifest+wasm，本地试装用）
/plugins-examples/*.jplug

# 前端依赖与构建产物
/web/node_modules/
/web/dist/
# WASM demo 产物（由 `pnpm build:wasm` / wasm-pack 生成，不入库）
/web/src/wasm-pkg/

# 系统/编辑器杂项
.DS_Store
*.log
Thumbs.db
