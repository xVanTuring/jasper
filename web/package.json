{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "build:wasm": "wasm-pack build ../wasm --target web --out-dir ../web/src/wasm-pkg",
    "build:demo": "pnpm build:wasm && VITE_DEMO=1 vite build"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
